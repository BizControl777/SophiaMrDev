{
  "name": "sophia-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "npm run dev --workspace=apps/backend",
    "mobile:dev": "npm run start --workspace=apps/mobile",
    "mobile:web": "npm run web --workspace=apps/mobile",
    "shared:build": "npm run build --workspace=packages/shared",
    "build": "npm run shared:build && npm run build --workspace=apps/backend",
    "start": "npm run start --workspace=apps/backend",
    "vercel-build": "npm install --legacy-peer-deps && npm run build"
  },
  "dependencies": {
    "ai": "^7.0.29",
    "react-markdown": "^10.1.0",
    "lightningcss-wasm": "^1.32.0"
  },
  "devDependencies": {}
}