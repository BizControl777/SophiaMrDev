## Copy to `.env.local` (recommended) or `.env`
## Never commit real keys.

# Prisma / DB (Supabase PostgreSQL)
# Obter em: Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# URL directa — necessária para o Prisma Migrate
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-central-1.supabase.com:5432/postgres"

# Auth — required, at least 32 characters
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32chars"

# LLM providers (set the ones you use)
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=

# M-Pesa — without MPESA_API_KEY, recharge is REJECTED unless simulation is explicitly enabled
# MPESA_API_HOST=api.sandbox.vm.co.mz
# MPESA_API_KEY=
# MPESA_PUBLIC_KEY=
# MPESA_SERVICE_PROVIDER_CODE=
# ALLOW_MPESA_SIMULATION=true   # local/dev only; ignored when NODE_ENV=production
